  @@schema("public")
}

model news_article {
  case_id        Int      @id @default(autoincrement())
  title          String
  link           String   @unique(map: "idx_news_article_link")
  published_date String   @db.VarChar(50)
  is_threat      Boolean? @default(false)
  source         String   @db.VarChar(50)

  @@index([source], map: "idx_news_article_source")
  @@index([title], map: "idx_news_article_title")
  @@index([title(ops: raw("gin_trgm_ops"))], map: "idx_news_article_title_gin", type: Gin)
  @@schema("scraper_service")
}
